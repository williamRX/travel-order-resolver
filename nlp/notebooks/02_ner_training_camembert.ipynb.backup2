    "# Charger le tokenizer CamemBERT Fast (nécessaire pour return_offsets_mapping)\n",
    "print(f\"🔄 Chargement du tokenizer Fast {MODEL_NAME}...\")\n",
    "tokenizer = CamembertTokenizerFast.from_pretrained(MODEL_NAME)\n",
    "print(f\"✅ Tokenizer Fast chargé\")\n",
    "print(f\"   Vocabulaire: {len(tokenizer)} tokens\")\n",
    "print(f\"   Type: {type(tokenizer).__name__} (supporte return_offsets_mapping)\")\n"
   ]
  },
