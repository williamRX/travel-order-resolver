    "# Entraînement\n",
    "print(\"🚀 Démarrage de l'entraînement...\")\n",
    "print(\"=\" * 80)\n",
    "print(f\"📊 Configuration:\")\n",
    "print(f\"   - Époques: {NUM_EPOCHS}\")\n",
    "print(f\"   - Batch size: {BATCH_SIZE}\")\n",
    "print(f\"   - Learning rate: {LEARNING_RATE}\")\n",
    "print(f\"   - Device: {device}\")\n",
    "print(f\"   - Total steps estimé: ~{len(train_dataset) // BATCH_SIZE * NUM_EPOCHS}\")\n",
    "print(f\"   - Logs toutes les 10 steps\")\n",
    "print(f\"   - Évaluation tous les 100 steps\")\n",
    "print(\"=\" * 80)\n",
    "print(\"\\n🔄 Entraînement en cours... (cela peut prendre 30-60 min avec GPU, 3-6h avec CPU)\\n\")\n",
    "\n",
    "# Lancer l'entraînement\n",
    "train_result = trainer.train()\n",
    "\n",
    "print(\"\\n\" + \"=\" * 80)\n",
    "print(\"✅ Entraînement terminé!\")\n",
    "print(f\"   Loss finale: {train_result.training_loss:.4f}\")\n",
    "print(f\"   Temps total: {train_result.metrics.get('train_runtime', 0):.1f}s ({train_result.metrics.get('train_runtime', 0)/60:.1f} min)\")\n",
    "print(f\"   Steps par seconde: {train_result.metrics.get('train_samples_per_second', 0):.2f}\")\n",
    "print(f\"   Époques complétées: {train_result.metrics.get('epoch', 0):.2f}\")\n",
    "\n",
    "# Afficher les métriques de validation\n",
    "if hasattr(trainer, 'state') and trainer.state.log_history:\n",
    "    print(\"\\n📊 Historique des métriques de validation:\")\n",
    "    print(\"=\" * 80)\n",
    "    eval_logs = [log for log in trainer.state.log_history if 'eval_loss' in log]\n",
    "    if eval_logs:\n",
    "        for log in eval_logs:\n",
    "            epoch = log.get('epoch', 'N/A')\n",
    "            step = log.get('step', 'N/A')\n",
    "            eval_loss = log.get('eval_loss', 'N/A')\n",
    "            eval_f1 = log.get('eval_f1', 'N/A')\n",
    "            eval_accuracy = log.get('eval_accuracy', 'N/A')\n",
    "            eval_precision = log.get('eval_precision', 'N/A')\n",
    "            eval_recall = log.get('eval_recall', 'N/A')\n",
    "            print(f\"   Époque {epoch:.2f} | Step {step} | Loss: {eval_loss:.4f} | F1: {eval_f1:.4f} | Accuracy: {eval_accuracy:.4f} | Precision: {eval_precision:.4f} | Recall: {eval_recall:.4f}\")\n",
    "    else:\n",
    "        print(\"   Aucune évaluation effectuée pendant l'entraînement\")\n",
    "    print(\"=\" * 80)\n"
   ]
