     ]
    }
   ],
   "source": [
    "# Charger le modèle CamemBERT pour Token Classification\n",
    "print(f\"🔄 Chargement du modèle {MODEL_NAME}...\")\n",
    "model = CamembertForTokenClassification.from_pretrained(\n",
    "    MODEL_NAME,\n",
    "    num_labels=NUM_LABELS,\n",
    "    id2label=ID2LABEL,\n",
    "    label2id=LABEL2ID\n",
    ")\n",
    "\n",
    "# Déplacer le modèle sur le device (GPU ou CPU)\n",
    "model.to(device)\n",
    "\n",
    "# Compter les paramètres\n",
    "total_params = sum(p.numel() for p in model.parameters())\n",
    "trainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "\n",
    "print(f\"✅ Modèle chargé\")\n",
    "print(f\"   Device: {device}\")\n",
    "print(f\"   Paramètres totaux: {total_params:,}\")\n",
    "print(f\"   Paramètres entraînables: {trainable_params:,}\")\n",
    "print(f\"   Labels: {NUM_LABELS} ({', '.join(LABELS)})\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Configuration de l'Entraînement\n",
    "\n",
    "**Objectif** : Configurer les paramètres d'entraînement avec Hugging Face Trainer.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Fonction de calcul des métriques définie\n"
     ]
    }
   ],
   "source": [
    "# Fonction pour calculer les métriques NER\n",
    "def compute_metrics(eval_pred):\n",
    "    \"\"\"Calcule les métriques NER (precision, recall, F1).\"\"\"\n",
    "    predictions, labels = eval_pred\n",
    "    \n",
    "    # Convertir les prédictions en labels\n",
    "    predictions = np.argmax(predictions, axis=2)\n",
    "    \n",
    "    # Ignorer les tokens padding (-100)\n",
    "    true_predictions = [\n",
    "        [ID2LABEL[p] for (p, l) in zip(prediction, label) if l != -100]\n",
    "        for prediction, label in zip(predictions, labels)\n",
    "    ]\n",
    "    true_labels = [\n",
    "        [ID2LABEL[l] for (p, l) in zip(prediction, label) if l != -100]\n",
    "        for prediction, label in zip(predictions, labels)\n",
    "    ]\n",
    "    \n",
    "    # Calculer les métriques avec seqeval\n",
    "    return {\n",
    "        \"accuracy\": accuracy_score(true_labels, true_predictions),\n",
    "        \"precision\": precision_score(true_labels, true_predictions),\n",
    "        \"recall\": recall_score(true_labels, true_predictions),\n",
    "        \"f1\": f1_score(true_labels, true_predictions),\n",
    "    }\n",
    "\n",
    "print(\"✅ Fonction de calcul des métriques définie\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
