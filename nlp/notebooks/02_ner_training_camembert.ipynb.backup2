   "source": [
    "# Fonction pour convertir les annotations en format IOB\n",
    "def align_tokens_with_entities(text, entities, tokenizer):\n",
    "    \"\"\"\n",
    "    Aligne les tokens avec les entités et retourne les labels au format IOB.\n",
    "    \n",
    "    Args:\n",
    "        text: Texte original\n",
    "        entities: Liste de tuples (start, end, label)\n",
    "        tokenizer: Tokenizer CamemBERT\n",
    "    \n",
    "    Returns:\n",
    "        tokens: Liste des tokens\n",
    "        labels: Liste des labels IOB correspondants\n",
    "        encoding: Encodage complet\n",
    "    \"\"\"\n",
    "    # Tokeniser le texte avec offset mapping\n",
    "    encoding = tokenizer(\n",
    "        text,\n",
    "        max_length=MAX_LENGTH,\n",
    "        padding='max_length',\n",
    "        truncation=True,\n",
    "        return_offsets_mapping=True,\n",
    "        return_tensors=None\n",
    "    )\n",
    "    \n",
    "    tokens = tokenizer.convert_ids_to_tokens(encoding['input_ids'])\n",
    "    offset_mapping = encoding['offset_mapping']\n",
    "    \n",
    "    # Initialiser tous les labels à 'O' (Outside)\n",
    "    labels = ['O'] * len(tokens)\n",
    "    \n",
    "    # Pour chaque entité, trouver les tokens correspondants\n",
    "    for start_char, end_char, entity_label in entities:\n",
    "        # S'assurer que les indices sont valides\n",
    "        if start_char < 0 or end_char > len(text) or start_char >= end_char:\n",
    "            continue\n",
    "            \n",
    "        # Trouver les tokens qui chevauchent cette entité\n",
    "        entity_tokens = []\n",
    "        for i, (token_start, token_end) in enumerate(offset_mapping):\n",
    "            # Ignorer les tokens spéciaux ([CLS], [SEP], padding)\n",
    "            # Les tokens spéciaux ont offset (0, 0)\n",
    "            if token_start == 0 and token_end == 0:\n",
    "                continue\n",
    "            \n",
    "            # Vérifier si le token chevauche l'entité\n",
    "            # Un token chevauche si : token_start < end_char ET token_end > start_char\n",
    "            # Cela signifie qu'il y a un chevauchement entre le token et l'entité\n",
    "            if token_start < end_char and token_end > start_char:\n",
    "                entity_tokens.append(i)\n",
    "        \n",
    "        # Assigner les labels IOB seulement si on a trouvé des tokens\n",
    "        if entity_tokens:\n",
    "            # Trier pour s'assurer qu'ils sont dans l'ordre\n",
    "            entity_tokens.sort()\n",
    "            # Premier token = B- (Beginning)\n",
    "            labels[entity_tokens[0]] = f\"B-{entity_label}\"\n",
    "            # Tokens suivants = I- (Inside)\n",
    "            for token_idx in entity_tokens[1:]:\n",
    "                labels[token_idx] = f\"I-{entity_label}\"\n",
    "    \n",
    "    return tokens, labels, encoding\n",
    "\n",
    "print(\"✅ Fonction d'alignement définie\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
